<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="TTSMixmaster" 
           Language="1033" 
           Version="$(Version)" 
           Manufacturer="Morningwood Gaming LLC" 
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
    
    <MajorUpgrade DowngradeErrorMessage="A newer version of TTSMixmaster is already installed." />
    <MediaTemplate EmbedCab="yes" />
    
    <Feature Id="ProductFeature" Title="TTSMixmaster" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="HarvestedFiles" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="TTSMixmaster" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="TTSMixmaster"/>
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents">
      <!-- Main executable (per-machine), file is the KeyPath -->
      <Component Id="MainExecutable" Directory="INSTALLFOLDER" Guid="*">
        <File Id="TTSMixmasterExe" 
              Source="$(var.SourceDir)\TTSMixmaster-installer.exe" 
              Name="TTSMixmaster.exe"
              KeyPath="yes" />
      </Component>

      <!-- Start Menu shortcut (per-user), HKCU registry value is the KeyPath -->
      <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="*">
        <Shortcut Id="StartMenuShortcut" 
                  Name="TTSMixmaster" 
                  Target="[INSTALLFOLDER]TTSMixmaster.exe" 
                  Description="TTSMixmaster - Last.fm to Tabletop Simulator Integration"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveProgramsFolder" 
                      Directory="ApplicationProgramsFolder" 
                      On="uninstall"/>
        <RegistryValue Root="HKCU" 
                       Key="Software\TTSMixmaster" 
                       Name="StartMenuShortcut" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="yes"/>
      </Component>

      <!-- Desktop shortcut (per-user), HKCU registry value is the KeyPath -->
      <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
        <Shortcut Id="DesktopShortcut" 
                  Name="TTSMixmaster" 
                  Target="[INSTALLFOLDER]TTSMixmaster.exe" 
                  Description="TTSMixmaster - Last.fm to Tabletop Simulator Integration"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" 
                       Key="Software\TTSMixmaster" 
                       Name="DesktopShortcut" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="yes"/>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
